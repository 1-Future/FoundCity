{
  "name": "lostcitynojagex",
  "version": "1.0.0",
  "description": "Clean rewrite of lostcity-ref RS225 server emulator",
  "type": "module",
  "private": true,
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "vitest",
    "test:dual": "vitest run test/integration/dual.test.ts",
    "test:dual:ui": "vitest --reporter=verbose test/integration/dual.test.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1",
    "ws": "^8.19.0"
  }
}
